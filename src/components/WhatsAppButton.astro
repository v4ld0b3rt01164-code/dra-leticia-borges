---
const { href, variant = 'primary' } = Astro.props;
const whatsappUrl = href || 'https://wa.me/5516992314853';
const label = Astro.props.label || 'Agende sua consulta';
---

<a
  href={whatsappUrl}
  target="_blank"
  rel="noopener noreferrer"
  class={`cta cta--${variant}`}
>
  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true" class="cta-icon">
    <path d="M17.5 14.5c-.3-.2-.8-.4-1.2-.3-.4.1-1.1.4-1.3.5-.2.1-.4 0-.6-.2-.8-.9-1.6-1.8-2.3-2.8-.1-.2 0-.4.2-.5l.8-.7c.2-.2.4-.5.5-.8s0-.7-.1-1c-.1-.3-.7-1.4-.9-1.8-.2-.4-.5-.5-.8-.5h-.7c-.3 0-.7.1-1 .4-.8.8-1.1 2-.6 3.1.7 1.5 1.8 2.8 3 3.8 1.3 1.1 2.8 1.9 4.4 2.3.5.1 1 .2 1.5.1.3 0 .7-.2.9-.5.3-.3.5-.7.4-1.1-.2-.7-.9-1.5-1.6-1.7Z" fill="currentColor"/>
    <path fill-rule="evenodd" clip-rule="evenodd" d="M3.7 19.9 4.8 16A9.1 9.1 0 0 1 3 11.6 9 9 0 1 1 6.2 19l-2.5.9Zm2.2-1.3-.6 2 2.1-.8.6.4a7.5 7.5 0 1 0-2.6-2.5l.5.9Z" fill="currentColor"/>
  </svg>
  {label}
</a>

<style>
  .cta {
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
    padding: 0.75em 1.5em;
    border-radius: 999px;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(0.9375rem, 1.2vw, 1.0625rem);
    letter-spacing: -0.01em;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    white-space: nowrap;
    line-height: 1;
  }
  .cta-icon {
    flex-shrink: 0;
  }
  .cta--primary {
    background: var(--oliva-campo);
    color: #fff;
    box-shadow: 0 2px 12px rgba(156, 177, 58, 0.35);
  }
  .cta--primary:hover {
    transform: translateY(-1px);
    box-shadow: 0 4px 18px rgba(156, 177, 58, 0.45);
  }
  .cta--outline {
    background: transparent;
    color: var(--oliva-campo);
    border: 2px solid var(--oliva-campo);
  }
  .cta--outline:hover {
    background: var(--oliva-campo);
    color: #fff;
  }
  .cta--fixed-mobile {
    position: fixed;
    bottom: var(--space-md);
    right: var(--space-md);
    z-index: 50;
    background: var(--oliva-campo);
    color: #fff;
    padding: 0.875em 1.75em;
    border-radius: 999px;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(0.9375rem, 1.2vw, 1.0625rem);
    letter-spacing: -0.01em;
    box-shadow: 0 4px 24px rgba(156, 177, 58, 0.4);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  .cta--fixed-mobile:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 28px rgba(156, 177, 58, 0.5);
  }

  @media (min-width: 768px) {
    .cta--fixed-mobile {
      display: none;
    }
  }
</style>
