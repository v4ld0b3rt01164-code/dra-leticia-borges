---
const { href, variant = 'primary' } = Astro.props;
const whatsappUrl = href || 'https://wa.me/5516992314853';
const label = Astro.props.label || 'Agende sua consulta';
---

<a
  href={whatsappUrl}
  target="_blank"
  rel="noopener noreferrer"
  class={`cta cta--${variant}`}
>
  <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" class="cta-icon">
    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/>
  </svg>
  {label}
</a>

<style>
  .cta {
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
    padding: 0.75em 1.5em;
    border-radius: 999px;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(0.9375rem, 1.2vw, 1.0625rem);
    letter-spacing: -0.01em;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    white-space: nowrap;
    line-height: 1;
  }
  .cta-icon {
    flex-shrink: 0;
  }
  .cta--primary {
    background: var(--oliva-campo);
    color: #fff;
    box-shadow: 0 2px 12px rgba(156, 177, 58, 0.35);
  }
  .cta--primary:hover {
    transform: translateY(-1px);
    box-shadow: 0 4px 18px rgba(156, 177, 58, 0.45);
  }
  .cta--outline {
    background: transparent;
    color: var(--oliva-campo);
    border: 2px solid var(--oliva-campo);
  }
  .cta--outline:hover {
    background: var(--oliva-campo);
    color: #fff;
  }
  .cta--fixed-mobile {
    position: fixed;
    bottom: var(--space-md);
    right: var(--space-md);
    z-index: 50;
    background: var(--oliva-campo);
    color: #fff;
    padding: 0.875em 1.75em;
    border-radius: 999px;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(0.9375rem, 1.2vw, 1.0625rem);
    letter-spacing: -0.01em;
    box-shadow: 0 4px 24px rgba(156, 177, 58, 0.4);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  .cta--fixed-mobile:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 28px rgba(156, 177, 58, 0.5);
  }

  @media (min-width: 768px) {
    .cta--fixed-mobile {
      display: none;
    }
  }
</style>
